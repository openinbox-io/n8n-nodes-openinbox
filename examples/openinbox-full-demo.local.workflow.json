    {
      "parameters": {
        "jsCode": "// Verify HMAC-SHA256 signature on the incoming OpenInbox webhook.\n// Signature header format: X-Webhook-Signature = \"t=<unix_ms>,v1=<hex_sha256>\"\n// Signed string: `${t}.${JSON.stringify(payload)}`\n// The OpenInbox Trigger node surfaces these headers as `__delivery` on the\n// item JSON (signature, event, deliveryId), not as raw HTTP headers.\n// Requires n8n to allow the `crypto` builtin: start n8n with\n//   NODE_FUNCTION_ALLOW_BUILTIN=crypto\nconst crypto = require('crypto');\n\nconst SECRET = $env.OPENINBOX_WEBHOOK_SECRET || 'replace-with-your-webhook-secret';\n\nconst input = $input.first().json;\nconst delivery = input.__delivery || {};\nconst sigHeader = delivery.signature;\nconst event = delivery.event;\nconst deliveryId = delivery.deliveryId;\n\nif (!sigHeader) {\n  throw new Error('Missing signature on __delivery — is this item from the OpenInbox Trigger node?');\n}\n\nconst parts = Object.fromEntries(sigHeader.split(',').map(p => p.split('=')));\nconst t = parts.t;\nconst v1 = parts.v1;\n\nif (!t || !v1) {\n  throw new Error(`Malformed signature header: ${sigHeader}`);\n}\n\n// Strip the helper field before re-serialising the body for HMAC.\nconst body = { ...input };\ndelete body.__delivery;\n\nconst signed = `${t}.${JSON.stringify(body)}`;\nconst expected = crypto.createHmac('sha256', SECRET).update(signed).digest('hex');\n\nconst expectedBuf = Buffer.from(expected, 'hex');\nconst receivedBuf = Buffer.from(v1, 'hex');\nconst valid =\n  expectedBuf.length === receivedBuf.length &&\n  crypto.timingSafeEqual(expectedBuf, receivedBuf);\n\nreturn [{\n  json: {\n    valid,\n    event,\n    deliveryId,\n    timestamp: t,\n    payload: body,\n  },\n}];\n"
      },
      "id": "00000000-0000-0000-0000-000000000041",
