    {
      "parameters": {
        "jsCode": "// Extract a 4-8 digit OTP / verification code from the email body.\nconst e = $input.first().json;\nconst text = (e.text_body || e.textBody || '') + '\\n' + (e.html_body || e.htmlBody || '');\nconst m = text.match(/\\b(\\d{4,8})\\b/);\nreturn [{\n  json: {\n    emailId: e.id,\n    from: e.from,\n    subject: e.subject,\n    otp: m ? m[1] : null,\n    receivedAt: e.received_at || e.receivedAt,\n  },\n}];\n"
      },
      "id": "00000000-0000-0000-0000-000000000045",
      "name": "Extract OTP",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 1140]
