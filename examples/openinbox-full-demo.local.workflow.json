      "id": "00000000-0000-0000-0000-000000000040",
      "name": "OpenInbox Trigger",
      "type": "CUSTOM.openInboxTrigger",
      "typeVersion": 1,
      "position": [-720, 1240],
      "credentials": {
        "openInboxApi": {
